{
  "[css]": {
    "editor.defaultFormatter": "vscode.css-language-features"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter"
  },
  "[terraform-vars]": {
    "editor.defaultFormatter": "hashicorp.terraform"
  },
  "[terraform]": {
    "editor.defaultFormatter": "hashicorp.terraform"
  },
  "[typescript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml",
    "editor.tabSize": 2
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "breadcrumbs.filePath": "on",
  "breadcrumbs.symbolPath": "on",
  "cSpell.enabledFileTypes": {
    "asciidoc": true,
    "c": true,
    "cpp": true,
    "csharp": true,
    "css": true,
    "git-commit": true,
    "go": true,
    "handlebars": true,
    "haskell": true,
    "jade": true,
    "java": true,
    "json": true,
    "latex": true,
    "less": true,
    "markdown": true,
    "php": true,
    "plaintext": true,
    "pug": true,
    "python": true,
    "restructuredtext": true,
    "rust": true,
    "scala": true,
    "scss": true,
    "swift": true,
    "text": true,
    "yaml": true,
    "yml": true
  },
  "cSpell.userWords": [
    "asynq",
    "autocapitalization",
    "autocorrection",
    "broccolini",
    "bson",
    "configurables",
    "dealloc",
    "deinit",
    "Deinitializing",
    "GHOZT",
    "Interactor",
    "interactors",
    "Keychain",
    "lerp",
    "lightbox",
    "lookbooks",
    "lpath",
    "ltxt",
    "mascarpone",
    "pannable",
    "parkade",
    "pointable",
    "projekt",
    "proji",
    "Refetches",
    "reinitialization",
    "sendgrid",
    "spase",
    "Styleable",
    "Sublayer",
    "sulphites",
    "togglable",
    "uncache",
    "unobserve",
    "UUID",
    "wordmark"
  ],
  "chat.editing.confirmEditRequestRetry": false,
  "css.validate": true,
  "debug.javascript.autoAttachFilter": "onlyWithFlag",
  "debug.onTaskErrors": "abort",
  "diffEditor.ignoreTrimWhitespace": false,
  "diffEditor.renderSideBySide": true,
  "editor.autoIndent": "advanced",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.fixAll.stylelint": "explicit",
    "source.organizeImports": "explicit"
  },
  "editor.copyWithSyntaxHighlighting": false,
  "editor.dragAndDrop": false,
  "editor.formatOnSave": false,
  "editor.gotoLocation.multipleDeclarations": "goto",
  "editor.gotoLocation.multipleDefinitions": "goto",
  "editor.gotoLocation.multipleImplementations": "goto",
  "editor.gotoLocation.multipleReferences": "goto",
  "editor.gotoLocation.multipleTypeDefinitions": "goto",
  "editor.hover.delay": 800,
  "editor.inlineSuggest.enabled": true,
  "editor.minimap.enabled": false,
  "editor.minimap.maxColumn": 100,
  "editor.quickSuggestions": {
    "comments": false,
    "other": true,
    "strings": false
  },
  "editor.quickSuggestionsDelay": 100,
  "editor.renderWhitespace": "boundary",
  "editor.rulers": [
    80,
    120,
    160
  ],
  "editor.smoothScrolling": true,
  "editor.stickyScroll.enabled": true,
  "editor.tabSize": 2,
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "keyword.other.dotenv",
        "settings": {
          "foreground": "#FF000000"
        }
      }
    ]
  },
  "editor.wordSeparators": "`~!@#$%^&*()=+[{]}\\|;:'\",.<>/?-",
  "emmet.showExpandedAbbreviation": "never",
  "eslint.codeAction.showDocumentation": {
    "enable": true
  },
  "eslint.format.enable": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "svelte"
  ],
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmPasteNative": false,
  "explorer.excludeGitIgnore": true,
  "files.associations": {
    "*.css": "tailwindcss",
    "*.geojson": "json",
    "*.liquid": "html",
    "*.region": "html",
    "*.strings": "swift",
    "*.tfbackend": "terraform-vars",
    ".dev.vars": "shellscript",
    ".env": "shellscript",
    ".eslintrc": "javascript",
    ".stylelintrc": "json",
    ".tslintrc": "json",
    ".vars": "shellscript",
    "Appfile": "ruby",
    "Fastfile": "ruby",
    "Matchfile": "ruby",
    "dockerfile.*": "dockerfile"
  },
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.cache": true,
    "**/.classpath": true,
    "**/.data": true,
    "**/.env": false,
    "**/.factorypath": true,
    "**/.hg": true,
    "**/.project": true,
    "**/.settings": true,
    "**/.svn": true,
    "**/CVS": true
  },
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.openRepositoryInParentFolders": "always",
  "git.pullTags": false,
  "github.copilot.nextEditSuggestions.enabled": false,
  "githubPullRequests.createOnPublishBranch": "never",
  "githubPullRequests.pullBranch": "never",
  "gitlens.advanced.messages": {
    "suppressLineUncommittedWarning": true
  },
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "gitlens.codeLens.enabled": false,
  "go.lintOnSave": "package",
  "go.toolsEnvVars": {
    "GO111MODULE": "on"
  },
  "go.toolsManagement.autoUpdate": true,
  "go.useLanguageServer": true,
  "gopls": {
    "ui.semanticTokens": true
  },
  "html.format.extraLiners": "",
  "html.format.indentInnerHtml": true,
  "html.format.wrapLineLength": 0,
  "isort.args": [
    "--multi-line=3",
    "--trailing-comma",
    "--force-grid-wrap=0",
    "--use-parentheses",
    "--line-width=88"
  ],
  "javascript.preferences.importModuleSpecifier": "relative",
  "javascript.preferences.quoteStyle": "single",
  "javascript.suggest.names": false,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "javascript.validate.enable": false,
  "less.validate": false,
  "markdown.preview.scrollEditorWithPreview": false,
  "markdown.preview.scrollPreviewWithEditor": false,
  "notebook.defaultFormatter": "ms-python.black-formatter",
  "partialDiff.commandsOnContextMenu": {
    "diffSelectionWithClipboard": false,
    "diffVisibleEditors": false,
    "markSection1": false,
    "markSection2AndTakeDiff": false,
    "togglePreComparisonTextNormalizationRules": false
  },
  "python.analysis.autoImportCompletions": true,
  "python.analysis.completeFunctionParens": true,
  "python.languageServer": "Pylance",
  "python.terminal.activateEnvironment": false,
  "redhat.telemetry.enabled": false,
  "scss.validate": false,
  "search.exclude": {
    "**/.netlify": true,
    "**/bower_components": true,
    "**/build": true,
    "**/node_modules": true,
    "package-lock.json": true,
    "yarn.lock": true
  },
  "security.workspace.trust.untrustedFiles": "open",
  "tailwindCSS.classFunctions": [
    "clsx",
    "classnames",
    "c"
  ],
  "tailwindCSS.colorDecorators": false,
  "terminal.integrated.persistentSessionScrollback": 1000,
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.stickyScroll.enabled": false,
  "terraform.languageServer.ignoreSingleFileWarning": true,
  "typescript.format.semicolons": "remove",
  "typescript.preferences.importModuleSpecifier": "relative",
  "typescript.preferences.importModuleSpecifierEnding": "js",
  "typescript.preferences.preferTypeOnlyAutoImports": false,
  "typescript.preferences.quoteStyle": "single",
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "workbench.colorCustomizations": {
    "editor.selectionBackground": "#d53c3c",
    "selection.background": "#d53c3c",
    "terminal.findMatchBackground": "#d53c3c80"
  },
  "workbench.editor.empty.hint": "hidden",
  "workbench.editorAssociations": {
    "*.svg": "default"
  },
  "workbench.iconTheme": "vs-minimal",
  "workbench.startupEditor": "newUntitledFile",
  "xml.format.enforceQuoteStyle": "preferred",
  "xml.format.spaceBeforeEmptyCloseTag": true,
  "xml.preferences.quoteStyle": "double",
  "xml.validation.resolveExternalEntities": true,
  "zenMode.centerLayout": false,
  "zenMode.showTabs": "none",
  "workbench.colorTheme": "Ayu Mirage",
  "chat.viewSessions.orientation": "stacked"
}
